# ---- App ------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
# Public https URL of this backend (used to build Plivo webhook/WS URLs).
PUBLIC_BASE_URL=https://call.karbonz.com

# ---- Security -------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string

# ---- Datastores -----------------------------------------------------------
# Supabase (async driver + SSL are applied automatically in config.py).
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Upstash — use the rediss:// URL (TLS). A shell-style value is auto-sanitized.
REDIS_URL=rediss://default:PASSWORD@your-host.upstash.io:6379

# ---- Providers ------------------------------------------------------------
SARVAM_API_KEY=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
OPENROUTER_API_KEY=

# ---- Cloudflare R2 (recordings — needed from Feature 5) -------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
